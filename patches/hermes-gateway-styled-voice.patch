+def _is_styled_voice_request(text: str) -> bool:
+    """Return True when the inbound text invokes the styled-voice skill."""
+    if not text:
+        return False
+    normalized = text.strip().lower()
+    return normalized.startswith("/styled-voice") or normalized.startswith("/styled_voice")
+
+
+def _build_audio_attachment_path_note(audio_paths: list[str]) -> str:
+    """Format cached audio attachment paths for model-visible context."""
+    lines = [f"[Audio attachment saved at: {path}]" for path in audio_paths if path]
+    return "\n".join(lines)
+
